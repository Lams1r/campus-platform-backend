# =============================================================
# 后端生产环境变量模板
# 部署到 A 服务器后改名为 app.env,放在 /opt/campus-platform/app/
# 不要把真实密码 commit 进 git
# =============================================================

SPRING_PROFILES_ACTIVE=prod

# 数据库(MySQL 与应用同机,走 127.0.0.1)
DB_URL=jdbc:mysql://127.0.0.1:3306/campus_system?useUnicode=true&characterEncoding=utf8&zeroDateTimeBehavior=convertToNull&useSSL=false&serverTimezone=GMT%2B8
DB_USERNAME=campus_app
DB_PASSWORD=请替换为强密码

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_PASSWORD=请替换为强密码

# JetCache 单独使用 Redis URI 形式(注意密码要 url-encode)
JETCACHE_REDIS_URI=redis://:请替换为强密码@127.0.0.1:6379/

# 上传文件持久化目录
UPLOAD_PATH=/opt/campus-platform/uploads
