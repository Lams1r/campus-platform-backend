# Frontend server under test.
TARGET_BASE_URL=http://8.138.10.124

# Backend API server under test.
API_BASE_URL=http://114.132.77.204:8080/api

# Optional tokens. Fill these to enable authenticated API/RBAC tests.
# You can generate them with: python scripts/get_token.py --role admin --auto
ADMIN_TOKEN=
TEACHER_TOKEN=
STUDENT_TOKEN=

# Optional test-login bypass. Requires teammate backend to enable the same secret.
TEST_LOGIN_SECRET=campus-test-login
TEST_LOGIN_CAPTCHA_KEY=__campus_test_login__
TEST_LOGIN_CAPTCHA_CODE=__campus_test_login__

# Optional login accounts used by scripts/get_token.py.
ADMIN_USERNAME=ldx2
ADMIN_PASSWORD=123456
TEACHER_USERNAME=ldx3
TEACHER_PASSWORD=123456
STUDENT_USERNAME=ldx1
STUDENT_PASSWORD=123456

# Test behavior.
REQUEST_TIMEOUT=15
STRICT_MODE=false
PERF_ROUNDS=5
LATENCY_AVG_MS=1200
LATENCY_MAX_MS=2500

# If your deployment uses a custom API prefix, keep this aligned with Nginx/Spring.
AUTH_HEADER_NAME=Authorization

# Xiaomi MiMo AI summary. Put the real key in .env on the test server.
AI_SUMMARY_ENABLED=true
MIMO_API_KEY=
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5-pro
MIMO_VERIFY_SSL=false
MIMO_MAX_TOKENS=4000
AI_SUMMARY_TIMEOUT=90

# One-click web runner. Keep host as 127.0.0.1 and expose it through Nginx.
WEB_RUNNER_HOST=127.0.0.1
WEB_RUNNER_PORT=8099
WEB_RUNNER_TOKEN=campus-test
